<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Logo -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop" />

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="🎮 BD Super Chat Alert" android:textSize="24sp" android:textColor="#E94560"
            android:textStyle="bold" android:gravity="center" android:paddingTop="8dp" />
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="bKash &amp; Nagad SMS → Stream Alert" android:textSize="12sp"
            android:textColor="#8888AA" android:gravity="center" android:paddingBottom="16dp" />

        <!-- Permissions -->
        <TextView android:id="@+id/tv_perm" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Checking..." android:textSize="12sp" android:padding="10dp"
            android:background="@drawable/card_bg" android:layout_marginBottom="10dp" />

        <!-- API Key -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginBottom="10dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="🔑 API Key" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold" android:paddingBottom="6dp" />
            <EditText android:id="@+id/et_api_key" android:layout_width="match_parent" android:layout_height="44dp"
                android:hint="Paste API key" android:textColor="#FFFFFF" android:textColorHint="#555577"
                android:background="@drawable/input_bg" android:padding="10dp" android:textSize="13sp"
                android:inputType="text" android:layout_marginBottom="10dp" />
            <Button android:id="@+id/btn_connect" android:layout_width="match_parent" android:layout_height="44dp"
                android:text="Connect" android:textColor="#FFFFFF" android:textAllCaps="false"
                android:textSize="14sp" android:background="@drawable/btn_primary" />
        </LinearLayout>

        <!-- Status -->
        <TextView android:id="@+id/tv_status" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Not connected" android:textColor="#AAAACC" android:textSize="12sp"
            android:padding="10dp" android:background="@drawable/card_bg" android:layout_marginBottom="10dp" />

        <!-- Synced Info -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginBottom="10dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="📡 Account" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold" android:paddingBottom="8dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Streamer" android:textColor="#8888AA" android:textSize="10sp" />
            <TextView android:id="@+id/tv_username" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="#FFFFFF" android:textSize="14sp" android:paddingBottom="6dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="OBS Browser Source" android:textColor="#8888AA" android:textSize="10sp" />
            <TextView android:id="@+id/tv_obs_url" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="#E94560" android:textSize="12sp" android:textIsSelectable="true"
                android:background="@drawable/input_bg" android:padding="8dp" android:layout_marginTop="2dp" android:layout_marginBottom="6dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Total Donations" android:textColor="#8888AA" android:textSize="10sp" />
            <TextView android:id="@+id/tv_total" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="—" android:textColor="#4CAF50" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Settings (editable, two-way sync) -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:layout_marginBottom="10dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="⚙️ Settings" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold" android:paddingBottom="8dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="8dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Alert Duration (sec)" android:textColor="#AAAACC" android:textSize="13sp" />
                <EditText android:id="@+id/et_duration" android:layout_width="70dp" android:layout_height="36dp"
                    android:background="@drawable/input_bg" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:gravity="center" android:inputType="number" android:text="5" android:padding="4dp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingBottom="10dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="Minimum Amount (৳)" android:textColor="#AAAACC" android:textSize="13sp" />
                <EditText android:id="@+id/et_min_amount" android:layout_width="70dp" android:layout_height="36dp"
                    android:background="@drawable/input_bg" android:textColor="#FFFFFF" android:textSize="14sp"
                    android:gravity="center" android:inputType="numberDecimal" android:text="0" android:padding="4dp" />
            </LinearLayout>

            <Button android:id="@+id/btn_save_settings" android:layout_width="match_parent" android:layout_height="40dp"
                android:text="💾  Save Settings" android:textColor="#FFFFFF" android:textAllCaps="false"
                android:textSize="13sp" android:background="@drawable/btn_secondary" />
        </LinearLayout>

        <!-- Service -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:background="@drawable/card_bg" android:padding="14dp"
            android:gravity="center_vertical" android:layout_marginBottom="10dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:text="🔔 SMS Listener" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
            <Switch android:id="@+id/switch_service" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:thumbTint="#E94560" android:trackTint="#333355" />
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
            <Button android:id="@+id/btn_test_sms" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                android:text="📤 Send Test" android:textColor="#FFFFFF" android:textAllCaps="false" android:textSize="12sp"
                android:background="@drawable/btn_primary" android:layout_marginEnd="6dp" />
            <Button android:id="@+id/btn_clear_log" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1"
                android:text="🗑 Clear Log" android:textColor="#FFFFFF" android:textAllCaps="false" android:textSize="12sp"
                android:background="@drawable/btn_secondary" />
        </LinearLayout>

        <!-- Log -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/card_bg" android:padding="14dp" android:minHeight="120dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="📋 Donation Log" android:textSize="14sp" android:textColor="#FFFFFF" android:textStyle="bold" android:paddingBottom="6dp" />
            <ScrollView android:layout_width="match_parent" android:layout_height="200dp">
                <TextView android:id="@+id/tv_log" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="No donations..." android:textColor="#CCCCDD" android:textSize="11sp" android:fontFamily="monospace" />
            </ScrollView>
        </LinearLayout>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Developed by jubiplays.com" android:textColor="#555577" android:textSize="10sp"
            android:gravity="center" android:paddingTop="14dp" android:paddingBottom="20dp" />
    </LinearLayout>
</ScrollView>
